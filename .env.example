# AurumQ-RL Environment Variables
# Copy to .env and fill in your values. .env is gitignored.

# === 数据库连接（仅 export_factor_panel.py 需要）===
# PostgreSQL with TimescaleDB
PG_URL=postgresql://user:password@localhost:5432/your_db

# === 训练配置 ===
# RL 训练输出根目录
RL_OUTPUT_DIR=./models

# Universe 过滤模式
# 选项: main_board_non_st (默认) / all_a / hs300 / zz500 / zz1000
RL_UNIVERSE_FILTER=main_board_non_st

# === 实验跟踪（可选）===
# 用 wandb 记录训练曲线（默认 offline）
WANDB_MODE=offline
WANDB_PROJECT=aurumq-rl
WANDB_DIR=./wandb

# 仅在显式上传时填这两个
# WANDB_API_KEY=
# WANDB_ENTITY=

# === 推理配置 ===
# ONNX 推理线程数（CPU only）
ONNX_INTRA_OP_THREADS=4
ONNX_INTER_OP_THREADS=2

# === Object storage (optional, for sharing real Parquet between machines) ===
# Fill these only if you use object storage (S3 / OSS / MinIO / GCS) to ship
# real factor panels between an extraction host and a training GPU box.
# Leave blank if you train locally with pre-computed Parquet files.
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_BUCKET_NAME=
OSS_PREFIX=

# === 数据时间范围 ===
# 全因子（含游资）训练区间
RL_TRAIN_START=2023-01-01
RL_TRAIN_END=2025-06-30
RL_TEST_START=2025-07-01
RL_TEST_END=2025-12-31

# 长历史（不含游资）
# RL_TRAIN_START=2017-08-01
# RL_TRAIN_END=2025-06-30
